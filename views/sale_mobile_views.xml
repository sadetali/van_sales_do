<odoo>
    <record id="sale_order_mobile_form" model="ir.ui.view">
        <field name="name">sale.order.mobile.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_save_do" string="Save DO" type="object" class="btn-primary" invisible="state not in ['draft', 'sent']"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_mobile_action" model="ir.actions.act_window">
        <field name="name">Mobile Sales Entry</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
