<odoo>
<template id="report_sale_compact">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="o">
<t t-call="web.basic_layout">
<div class="page" style="font-family:Arial, Helvetica, sans-serif; font-size:11px; line-height:1.25; color:#000;">

<table style="width:100%; margin:0 0 3px 0; border-collapse:collapse;">
<tr>
<td style="width:65%; vertical-align:top;">
<div style="font-size:15px; font-weight:bold;"><span t-field="o.company_id.name"/></div>
<div style="font-size:11px;">
<span t-field="o.company_id.city"/><t t-if="o.company_id.country_id">, <span t-field="o.company_id.country_id.name"/></t>
</div>
</td>
<td style="width:35%; text-align:right; vertical-align:top; font-size:10.5px;">
<div t-if="o.company_id.phone">Tel: <span t-field="o.company_id.phone"/></div>
<div t-if="o.company_id.email">Email: <span t-field="o.company_id.email"/></div>
<div t-if="o.company_id.vat">TRN: <span t-field="o.company_id.vat"/></div>
</td>
</tr>
</table>

<h4 style="text-align:center; margin:4px 0 5px 0; font-size:16px; font-weight:bold; letter-spacing:.5px; text-decoration:underline;">
<t t-if="o.state in ['draft','sent']">DELIVERY ORDER</t><t t-else="">SALES ORDER</t>
</h4>

<table style="width:100%; font-size:11px; margin-bottom:5px; border-collapse:collapse;">
<tr>
<td style="border:1px solid #000; padding:4px 5px; width:50%;"><strong>Customer:</strong> <span t-field="o.partner_id"/></td>
<td style="border:1px solid #000; padding:4px 5px; width:25%;"><strong>No:</strong> <span t-field="o.name"/></td>
<td style="border:1px solid #000; padding:4px 5px; width:25%;"><strong>Date:</strong> <span t-field="o.date_order" t-options="{'widget': 'date'}"/></td>
</tr>
</table>

<table style="width:100%; border-collapse:collapse; font-size:11px;">
<thead>
<tr>
<th style="border:1px solid #000; padding:5px 4px; width:6%; text-align:center;">Sl</th>
<th style="border:1px solid #000; padding:5px 4px; width:52%; text-align:left;">Product</th>
<th style="border:1px solid #000; padding:5px 4px; width:12%; text-align:right;">Qty</th>
<th style="border:1px solid #000; padding:5px 4px; width:14%; text-align:right;">Rate</th>
<th style="border:1px solid #000; padding:5px 4px; width:16%; text-align:right;">Amount</th>
</tr>
</thead>
<tbody>
<tr t-foreach="o.order_line" t-as="l">
<td style="border:1px solid #999; padding:5px 4px; text-align:center;"><span t-esc="l_index + 1"/></td>
<td style="border:1px solid #999; padding:5px 4px;"><span t-field="l.product_id.display_name"/></td>
<td style="border:1px solid #999; padding:5px 4px; text-align:right;"><span t-field="l.product_uom_qty"/></td>
<td style="border:1px solid #999; padding:5px 4px; text-align:right;"><span t-field="l.price_unit"/></td>
<td style="border:1px solid #999; padding:5px 4px; text-align:right;"><span t-field="l.price_subtotal"/></td>
</tr>
</tbody>
</table>

<table style="width:38%; margin-left:auto; margin-top:8px; font-size:11px; border-collapse:collapse;">
<tr><td style="border:1px solid #000; padding:4px;">Subtotal</td><td style="border:1px solid #000; padding:4px; text-align:right;"><span t-field="o.amount_untaxed"/></td></tr>
<tr><td style="border:1px solid #000; padding:4px;">VAT</td><td style="border:1px solid #000; padding:4px; text-align:right;"><span t-field="o.amount_tax"/></td></tr>
<tr style="font-weight:bold;"><td style="border:1px solid #000; padding:4px;">Total</td><td style="border:1px solid #000; padding:4px; text-align:right;"><span t-field="o.amount_total"/></td></tr>
</table>

<table style="width:100%; margin-top:30px; font-size:11px;">
<tr>
<td style="width:50%;">Customer Signature __________________</td>
<td style="width:50%; text-align:right;">Authorized Signature __________________</td>
</tr>
</table>

</div>
</t>
</t>
</t>
</template>
</odoo>
